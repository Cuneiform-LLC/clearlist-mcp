{
  "name": "@clearlist/mcp-server",
  "version": "0.3.1",
  "mcpName": "io.github.Cuneiform-LLC/clearlist",
  "private": false,
  "description": "ClearList MCP Server — AI agent interface to the ClearList API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clearlist": "dist/cli.js",
    "clearlist-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cuneiform-LLC/clearlist-mcp.git",
    "directory": "mcp-server"
  },
  "homepage": "https://clearlist.me/developers",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "cli",
    "clearlist"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"try{const{chmodSync}=require('fs');chmodSync('dist/index.js',0o755);chmodSync('dist/cli.js',0o755)}catch(e){}\"",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "fast-uri": ">=3.1.1",
    "protobufjs": ">=7.5.8 <8",
    "@protobufjs/utf8": ">=1.1.1",
    "brace-expansion": ">=1.1.12 <2 || >=2.0.2 <3",
    "uuid": ">=11.1.1 <12",
    "ws": ">=8.20.1"
  }
}
